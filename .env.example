# Obrigatórios
CLICKUP_API_TOKEN=pk_xxx            # token pessoal, vai puro no header Authorization
CLICKUP_WEBHOOK_SECRET=xxx          # retornado ao criar o webhook no ClickUp

# Opcionais (têm fallback)
GENERATE_TOKEN=xxx                  # protege POST /generate (n8n envia "Authorization: Bearer <token>"); sem ele, endpoint aberto
OPENAI_API_KEY=sk-xxx               # gpt-5-nano condensa requisitos/benefícios; sem a chave, usa as listas originais
CLICKUP_FIELD_VARIACOES=Nomenclaturas  # nome do campo customizado com as variações de cargo (match por inclusão, ignora emoji)
PEXELS_KEY=
N8N_WEBHOOK_URL=https://foursales-company.app.n8n.cloud/webhook/buscar-vaga-sistema-arte
PORT=3001
